# ─── SERVER ENVIRONMENT (EXAMPLE) ────────────────────────────────────────────
# Copy this file to .env and fill in your values. Never commit .env directly.

# Server port (default: 5000)
PORT=5000

# Set to 'production' when deploying
NODE_ENV=production

# Set to 'true' on Render to use local execution engine instead of Docker
RENDER=false

# Docker host (leave empty for local Docker Desktop default)
# DOCKER_HOST=

# Allowed CORS origins (comma-separated)
# CLIENT_ORIGIN=http://localhost:3000
